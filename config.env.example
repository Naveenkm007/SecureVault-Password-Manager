# SecureVault Environment Configuration
# Copy this file to .env and fill in your actual values

# Supabase Configuration
REACT_APP_SUPABASE_URL=your_supabase_project_url
REACT_APP_SUPABASE_ANON_KEY=your_supabase_anon_key

# App Configuration
REACT_APP_APP_NAME=SecureVault
REACT_APP_APP_VERSION=2.0.0
REACT_APP_APP_DESCRIPTION=Your most secure password manager

# Security Configuration
REACT_APP_ENCRYPTION_ITERATIONS=100000
REACT_APP_SESSION_TIMEOUT=3600000
REACT_APP_AUTO_LOCK_DELAY=300000

# Feature Flags
REACT_APP_ENABLE_BIOMETRICS=true
REACT_APP_ENABLE_CLOUD_SYNC=false
REACT_APP_ENABLE_PUSH_NOTIFICATIONS=false
REACT_APP_ENABLE_OFFLINE_MODE=true

# Analytics (Optional)
REACT_APP_ANALYTICS_ID=your_analytics_id
REACT_APP_ANALYTICS_ENABLED=false

# Development
REACT_APP_DEBUG_MODE=false
REACT_APP_LOG_LEVEL=info
